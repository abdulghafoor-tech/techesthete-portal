# JWT Secret - Change this to a random secure string
JWT_SECRET=your_jwt_secret_here

# Email Configuration (Gmail)
# To send real emails, configure Gmail App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create an App Password for "Mail"
# 5. Copy the 16-character password and paste below
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Server Configuration
HOST=0.0.0.0
PORT=4000

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# Gmail OAuth Configuration
# Create credentials at: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=http://localhost:4000/api/gmail/callback

# Database Configuration (PostgreSQL)
# Update config/config.json with your database credentials
